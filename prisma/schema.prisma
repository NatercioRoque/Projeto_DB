// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  id         Int     @id @default(autoincrement())
  nome       String
  cpf        String  @db.VarChar(14)
  telefone   String  @db.VarChar(15)
  e_flamengo Boolean @default(false)
  fa_OP      Boolean @default(false)
  souseano   Boolean @default(false)

  // Relação 1 para N: um cliente pode ter várias comandas
  comandas Comanda[]
}

model Comanda {
  id   Int      @id @default(autoincrement())
  data DateTime @default(now())
  mesa Int  @db.SmallInt

  // Relação com Cliente
  clienteId Int
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  // Relação com Garçom
  id_garcom Int?
  garcom    Garcom?  @relation(fields: [id_garcom], references: [Id_garcom])

  itens      Int[]
  total      Decimal  @db.Decimal(7, 2)
  status     String   @default("ATIVA")
  finalizada Boolean  @default(false)
  pagamento  String?
}

model Garcom {
  Id_garcom    Int      @id @default(autoincrement())
  nome         String
  data_admicao DateTime @db.Date // Dia, Mês e Ano
  salario      Decimal  @db.Decimal(6, 2) // Max 9999.99
  
  comandas     Comanda[]
}

model Cardapio {
  id         Int     @id @default(autoincrement())
  nome       String
  valor      Decimal @db.Decimal(6, 2)
  categoria  String
  disponivel Boolean
  
  // Relacionamento 1-para-1
  bebida     Bebida?
}

model Bebida {
  id       Int      @id
  tipo     String
  safra    Int?     @db.SmallInt // 4 caracteres para o ano da safra

  // A chave estrangeira "id" faz referência direta ao "id" do Cardapio
  cardapio Cardapio @relation(fields: [id], references: [id])
}
