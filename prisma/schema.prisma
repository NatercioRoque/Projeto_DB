// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Mesa {
  numero   Int       @id @db.SmallInt
  data     DateTime  @default(now())
  // Relação 1 para N: uma mesa pode ter várias comandas
  comandas Comanda[]
}

model Cliente {
  id       Int    @id @default(autoincrement())
  nome     String
  cpf      String @db.VarChar(14)
  telefone String @db.VarChar(15)

  // Relação 1 para N: um cliente pode ter várias comandas
  comandas Comanda[]
}

model Comanda {
  id   Int      @id @default(autoincrement())
  data DateTime @default(now())

  // Relação com Mesa
  mesaId Int  @db.SmallInt
  mesa   Mesa @relation(fields: [mesaId], references: [numero])

  // Relação com Cliente
  clienteId Int
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  itens Int[]
  total Decimal @db.Decimal(7, 2)
}
